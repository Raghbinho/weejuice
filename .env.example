# ─── Base de données ───────────────────────────────────────────────
# SQLite par défaut (fichier local). Migrer vers Postgres plus tard :
# changer le provider dans prisma/schema.prisma et cette URL.
DATABASE_URL="file:./data/weejuice.db"

# ─── Admin ─────────────────────────────────────────────────────────
# Mot de passe du tableau d'administration (/admin).
ADMIN_PASSWORD="change-moi"

# ─── Devise & localisation (marché tunisien par défaut) ────────────
# Tout est modifiable ici SANS toucher au code.
NEXT_PUBLIC_CURRENCY_CODE="TND"
NEXT_PUBLIC_CURRENCY_SYMBOL="TND"     # mettre "د.ت" pour l'affichage arabe
NEXT_PUBLIC_CURRENCY_DECIMALS="3"     # millimes
NEXT_PUBLIC_CURRENCY_POSITION="after" # after -> "5,500 TND" | before -> "TND 5,500"
NEXT_PUBLIC_LOCALE="fr-TN"            # fr-TN | ar-TN | en (i18n prêt)
NEXT_PUBLIC_TIMEZONE="Africa/Tunis"

# ─── Livraison (optionnel, en TND) ─────────────────────────────────
NEXT_PUBLIC_DELIVERY_FEE="0"
NEXT_PUBLIC_DELIVERY_FREE_ABOVE="0"

# ─── Notification propriétaire (tout optionnel) ────────────────────
# Sans configuration, chaque commande est loggée dans la console serveur
# et reste consultable dans /admin.

# Email (via Resend — https://resend.com)
# RESEND_API_KEY="re_xxx"
# OWNER_EMAIL="proprietaire@example.com"
# FROM_EMAIL="WeeJuice <commandes@votre-domaine.tn>"

# WhatsApp — génère un lien wa.me cliquable (numéro au format international)
# OWNER_WHATSAPP="+21620123456"

# Webhook générique (Slack / Zapier / n8n / Make…)
# OWNER_WEBHOOK_URL="https://hooks.slack.com/services/xxx"
